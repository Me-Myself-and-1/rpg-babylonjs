{
	"compilerOptions": {
		"target": "es6",
		"lib": [
			"dom",
			"es6"
		],
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noResolve": false,
		"isolatedModules": true,
		"removeComments": true,
		"esModuleInterop": true,
		"noImplicitAny": false,
		"noUnusedLocals": false,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"skipLibCheck": true
	},
	"include": [
		"src"
	]
}